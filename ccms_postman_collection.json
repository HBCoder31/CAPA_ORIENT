    {
      "name": "4. Technical Services (TS) Stage",
      "item": [
        {
          "name": "Schedule Customer Visit (TS Head)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actionType\": \"visit-schedule\",\n  \"visitDate\": \"2026-07-22 14:00:00\",\n  \"departureDate\": \"2026-07-22 09:00:00\",\n  \"returnDate\": \"2026-07-23 18:00:00\",\n  \"visitMembers\": [100003],\n  \"remarks\": \"Onsite inspection of batch Dryer 3 rolls.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/ts-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "ts-review"
              ]
            },
            "description": "Schedules a customer site visit. Restricted to TS Head or Administrator. Transitions status to 'Visit Scheduled' and assigns to KAM for coordination."
          },
          "response": []
        },
        {
          "name": "Submit Field Remarks (Visit Member)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remarks\": \"Inspected rolls on-site. Moisture lines and damp reams confirmed. Recommend forwarding to QC for lab verification.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/visit-remarks",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "visit-remarks"
              ]
            },
            "description": "Submits field observations. Must be called by the assigned visit member employee. Once all members submit remarks, complaint automatically returns to Under TS Review (status 18) assigned to TS Head."
          },
          "response": []
        },
        {
          "name": "Forward TS Review to QC (TS Head)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actionType\": \"forward\",\n  \"remarks\": \"Onsite check completed. Sample forwarded to QC Lab for chemical analysis.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/ts-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "ts-review"
              ]
            },
            "description": "Completes TS review and forwards complaint to Quality Control (moves to status 21 'QC Review Pending')."
          },
          "response": []
        },
        {
          "name": "Get TS Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/complaints/88/ts-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "ts-review"
              ]
            },
            "description": "Loads TS investigation details, visits, and assigned visit members."
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Quality Control (QC) Stage",
      "item": [
        {
          "name": "Request Physical Sample",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actionType\": \"sample-request\",\n  \"remarks\": \"Requesting 2 reams from batch Dryer 3 for GSM check.\",\n  \"sampleRequestDate\": \"2026-07-17 12:00:00\",\n  \"sampleContactEmployeeId\": 100003,\n  \"courierDetails\": \"Orient Paper Dispatch Desk\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/qc-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "qc-review"
              ]
            },
            "description": "Requests customer sample. Transitions complaint to 'Waiting Sample' (status 20) and pauses SLA timer."
          },
          "response": []
        },
        {
          "name": "Log Sample Receipt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actionType\": \"sample-receive\",\n  \"sampleCondition\": \"Intact package, slightly damp edges\",\n  \"remarks\": \"Sample received at QC desk.\",\n  \"sampleDispatchedDate\": \"2026-07-18 10:00:00\",\n  \"sampleReceivedDate\": \"2026-07-20 11:30:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/qc-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "qc-review"
              ]
            },
            "description": "Records receipt of requested sample, resets SLA window to exactly 3 days, and unpauses SLA timer."
          },
          "response": []
        },
        {
          "name": "Forward QC Review to QC Head",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actionType\": \"forward\",\n  \"sampleVerified\": true,\n  \"observation\": \"Moisture level verified at 9.6%. Breaches Orient Paper threshold (7.5%).\",\n  \"recommendation\": \"Approve customer replacement or commercial credit note.\",\n  \"remarks\": \"Technical defect is genuine. Forwarding to QC Head for final confirmation.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/qc-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "qc-review"
              ]
            },
            "description": "Forwards analysis details to the QC Head. Moves complaint status to 'QC Head Pending' (status 84)."
          },
          "response": []
        },
        {
          "name": "Get QC Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/complaints/88/qc-review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "qc-review"
              ]
            },
            "description": "Retrieves QC inspection, sample tracking logs, and image responses."
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. CAPA & Operations",
      "item": [
        {
          "name": "Submit CAPA Worksheet (Operations Engineer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rootCause\": \"Calibration issue in Dryer section 3 control valve.\",\n  \"correctiveAction\": \"Recalibrated sensor controls and locked valve mechanism.\",\n  \"preventiveAction\": \"Added valve lock checklist to weekly preventative maintenance logs.\",\n  \"remarks\": \"CAPA details finalized.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/capa",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "capa"
              ]
            },
            "description": "Logs Corrective and Preventive Actions. Moves complaint status to 'Ops Head Approval' (status 23)."
          },
          "response": []
        },
        {
          "name": "Get CAPA Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/complaints/88/capa",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "capa"
              ]
            },
            "description": "Loads the CAPA worksheet details for review."
          },
          "response": []
        }
      ]
    },
    {
      "name": "7. Approvals Stage",
      "item": [
        {
          "name": "Approve / Forward Stage",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stage\": \"kam\",\n  \"remarks\": \"KAM verification check approved. Forwarding to TS.\",\n  \"severityId\": 32\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/approve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "approve"
              ]
            },
            "description": "Progresses a complaint past an approval node. `stage` parameters supported:\n- **`kam`**: KAM approves intake and forwards to TS Review (severityId optional update)\n- **`qc-head`**: QC Head approves QC review details, forwards to CAPA Pending\n- **`ops-head`**: Ops Head approves CAPA worksheet, forwards to Marketing Review\n- **`marketing-pm`**: PM reviews commercial proposal, forwards to Marketing Head\n- **`marketing-head`**: Marketing Head approves commercial settlement (requires `settlementAmount`). Moves to Finance Pending (<= 1 Lakh) or MD Approval (> 1 Lakh)\n- **`md`**: Managing Director approves settlement. Moves to Finance Pending\n- **`finance-head`**: Finance Head approves issued Credit Note. Closes the complaint."
          },
          "response": []
        }
      ]
    },
    {
      "name": "8. Finance Execution",
      "item": [
        {
          "name": "Issue Credit Note (Finance Executive)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"creditNoteNumber\": \"SAP-CN-2026-9912\",\n  \"creditNoteDate\": \"2026-07-25\",\n  \"creditNoteAmount\": 65000,\n  \"fiscalYear\": \"2026\",\n  \"companyCode\": \"OPM_PAPER\",\n  \"remarks\": \"SAP credit note sync complete.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/finance",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "finance"
              ]
            },
            "description": "Prepares and posts credit note details from SAP. Moves complaint to 'Credit Note Pending' (status 83) assigned to Finance Head."
          },
          "response": []
        }
      ]
    },
    {
      "name": "9. Reopening & Actions",
      "item": [
        {
          "name": "Reopen Closed Complaint (KAM only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"reopen\",\n  \"remarks\": \"Customer claims moisture issue is still visible in replacement batches. Reopening for onsite audit.\",\n  \"targetStageId\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints/88/action",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints",
                "88",
                "action"
              ]
            },
            "description": "Reopens a closed complaint within the permitted 7-day window. Only authorized for the mapped KAM or Admin. Customer accounts are blocked. Re-routes to the targeted stage (usually TS Review)."
          },
          "response": []
        }
      ]
    },
