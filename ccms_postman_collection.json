                "{{base_url}}"
              ],
              "path": [
                "complaints"
              ]
            },
            "description": "Loads complaints list filtered by the logged-in user's role-based visibility rules."
          },
          "response": []
        },
        {
          "name": "Get Complaint Details",
          "request": {
            "method": "GET",
            "header": [],
