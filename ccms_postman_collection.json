    {
      "name": "3. Core Complaints",
      "item": [
        {
          "name": "Log Complaint (Intake)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Moisture line defects on coping paper reams\",\n  \"description\": \"Moisture tests exceed maximum allowable limit (standard 7.5%, tested 9.5%).\",\n  \"priorityId\": 32,\n  \"lineItems\": [\n    {\n      \"invoiceNo\": \"INV100009\",\n      \"lineItem\": 1,\n      \"defectiveQty\": 3.5,\n      \"categoryId\": 38,\n      \"defectNatureId\": 43,\n      \"customerRemarks\": \"Moisture content OPM limits breach.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/complaints",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "complaints"
              ]
            },
            "description": "Submits a new customer complaint. Automatically routes to KAM Verification Pending."
          },
          "response": []
        },
        {
          "name": "Get Complaints List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/complaints",
